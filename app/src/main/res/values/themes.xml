<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.OruBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/green_primary</item>
        <item name="android:colorBackground">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/ink_soft</item>
    </style>

    <!-- Large, high-contrast primary action button used across screens. -->
    <style name="Widget.OruBar.BigButton" parent="Widget.MaterialComponents.Button">
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">64dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.OruBar.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Text.OruBar.Label" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/ink_soft</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="Text.OruBar.Value" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
