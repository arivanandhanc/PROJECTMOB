<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/confirm_title"
            android:textColor="@color/ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- ===== Error state ===== -->
        <LinearLayout
            android:id="@+id/errorPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:padding="20dp"
                android:background="@color/warn_bg"
                android:textColor="@color/danger"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanAgainError"
                style="@style/Widget.OruBar.BigButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/action_scan_again" />
        </LinearLayout>

        <!-- ===== Success state ===== -->
        <LinearLayout
            android:id="@+id/successPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Spoof warning banner -->
            <TextView
                android:id="@+id/spoofWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:padding="16dp"
                android:background="@color/warn_bg"
                android:textColor="@color/warn_ink"
                android:textSize="16sp"
                android:textStyle="bold"
                android:drawablePadding="8dp"
                app:drawableStartCompat="@android:drawable/ic_dialog_alert"
                android:text="@string/confirm_spoof_warning"
                android:visibility="gone" />

            <TextView style="@style/Text.OruBar.Label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="28dp" android:text="@string/confirm_paying_to" />

            <TextView
                android:id="@+id/payeeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/ink"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView style="@style/Text.OruBar.Label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:text="@string/confirm_upi_id" />

            <TextView
                android:id="@+id/payeeVpa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/ink"
                android:textSize="22sp"
                android:textIsSelectable="true" />

            <TextView
                android:id="@+id/seenNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/ink_soft"
                android:textSize="14sp" />

            <TextView style="@style/Text.OruBar.Label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:text="@string/confirm_amount" />

            <!-- Fixed amount (QR carried am=) -->
            <TextView
                android:id="@+id/amountFixed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/green_dark"
                android:textSize="36sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Amount entry (amount-less QR) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/amountInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/confirm_enter_amount"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/amountInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textSize="28sp"
                    android:maxLength="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/confirm_cap_note"
                android:textColor="@color/ink_soft"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPay"
                style="@style/Widget.OruBar.BigButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/confirm_pay_button" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
