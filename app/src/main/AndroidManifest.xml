<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      OruBar Pay requests exactly ONE permission: CAMERA (to scan QR codes).
      There is intentionally NO INTERNET permission — the OS itself then blocks
      any network call, making the "zero-network" claim verifiable in airplane
      mode (blueprint §4.3, §5.6). No SMS, no CALL_PHONE, no phone-state reads.
    -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!--
      Optional "Pay automatically" mode (user opts in). CALL_PHONE lets the app
      dial *99# itself; the accessibility service then fills the menu steps up to
      the PIN. Both are user-granted. There is still NO INTERNET permission, so
      nothing the app sees can leave the device.
    -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.flash"
        android:required="false" />
    <!-- CALL_PHONE implies telephony; mark it optional so Wi-Fi-only tablets can
         still install and use the scan/manual flow. -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!--
      Android 11+ package visibility: declare that we look up a dialer for the
      *99# ACTION_DIAL intent, so resolveActivity() can see it. Without this,
      canDial() could wrongly report "no dialer" on API 30+.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OruBar">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ScannerActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ConfirmActivity"
            android:exported="false" />

        <activity
            android:name=".ui.CheatCardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.HistoryActivity"
            android:exported="false" />

        <activity
            android:name=".ui.HelpActivity"
            android:exported="false" />

        <!-- Auto-fill the *99# menu up to the PIN. User-enabled in Settings. -->
        <service
            android:name=".service.UssdAutomatorService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/ussd_automator_config" />
        </service>

    </application>

</manifest>
